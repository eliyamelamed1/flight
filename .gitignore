# Local Claude Code agent config / skill library — not part of this toolkit
.claude/

# Rendered build artifact (ADR-0008) — generated per build, never committed
config.json

# Per-kit runtime assets created beside the scripts by takeoff/landing — never commit
repo/
transfer/
*.bundle

# The REAL dictionary holds internal-specific values and must never reach the toolkit
# repo (it travels to the external side). Only dictionary.sample.json is committed.
dictionary.json

# The REAL repos config holds per-kit remote URLs (the internal server URL must never
# reach the toolkit repo / external side). Only repos.sample.json is committed.
repos.json

# OS / editor noise
Thumbs.db
.DS_Store
